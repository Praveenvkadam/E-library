# ─────────────────────────────────────────────────────────────────────────────
# AiService — Environment Configuration (Sarvam.ai Edition)
# E-Library Spring Boot Microservice Project
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8085

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://aq199075_db_user:dobqKldjAkaYHWKW@cluster0.tiy8xeh.mongodb.net/service?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must match the JWT_SECRET in your Spring Boot Authentication service
JWT_SECRET=10ccf6ca7a7e8b7ae52860580b6d87ef65fb292133748be1220888a2566e0649

# ─── Eureka Service Discovery ─────────────────────────────────────────────────
EUREKA_HOST=localhost
EUREKA_PORT=8761
SERVICE_HOST=localhost
SERVICE_NAME=AI-SERVICE

# ─────────────────────────────────────────────────────────────────────────────
# SARVAM.AI  ✦  Get your key at: https://dashboard.sarvam.ai
# ─────────────────────────────────────────────────────────────────────────────
SARVAM_API_KEY=sk_c66bzou4_TXnCOnFtMYlKetAXNd5FnHGq
SARVAM_BASE_URL=https://api.sarvam.ai

# ─── Sarvam Models ────────────────────────────────────────────────────────────
# Chat / Summarization / Sentiment / Recommendations
SARVAM_CHAT_MODEL=sarvam-m

# Text-to-Speech (Bulbul v3) — 10 Indian languages + English, 30+ voices
SARVAM_TTS_MODEL=bulbul:v1
SARVAM_TTS_DEFAULT_SPEAKER=meera
# Available speakers: meera, pavithra, maitreyi, arvind, amol, amartya
SARVAM_TTS_DEFAULT_PITCH=0
SARVAM_TTS_DEFAULT_PACE=1.0

# Speech-to-Text (Saaras v3) — 22 Indian languages
SARVAM_STT_MODEL=saaras:v3

# Translation (Mayura v1) — 22 Indic languages + English
SARVAM_TRANSLATE_MODEL=mayura:v1

# ─── File Upload ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# ─── Summary Cache TTL (30 days in seconds) ───────────────────────────────────
CACHE_TTL_SECONDS=2592000

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_GENERAL=200
RATE_LIMIT_MAX_SUMMARY=20
RATE_LIMIT_MAX_TTS=50
RATE_LIMIT_MAX_ANALYSIS=30

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=combined

# ─── Related Microservices ────────────────────────────────────────────────────
BOOK_UPLOAD_SERVICE_URL=http://localhost:8082
API_GATEWAY_URL=http://localhost:8080